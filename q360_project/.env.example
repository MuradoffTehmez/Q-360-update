# ============================================
# Q360 — Environment Variables Example
# ============================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================

# Django Settings
SECRET_KEY=change-this-to-a-random-50-character-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# SEO / Site Identity (change to your production domain)
SITE_DOMAIN=yourdomain.com
SITE_PROTOCOL=https

# Database Configuration (PostgreSQL 16)
DB_NAME=q360_db
DB_USER=postgres
DB_PASSWORD=Qazzaq2020.TM
DB_HOST=db
DB_PORT=5432

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@q360.gov.az

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000

# Security Settings (set to True when HTTPS is available)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Superuser Auto-Creation (Docker first run)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@q360.gov.az
DJANGO_SUPERUSER_PASSWORD=change-this-password

# Sentry Error Tracking (optional)
SENTRY_DSN=

# Company Settings
COMPANY_NAME=Q360 Evaluation System

# 2FA Settings
2FA_REQUIRED_FOR_ADMINS=True
2FA_SESSION_TIMEOUT=60

# Rate Limiting
RATELIMIT_ENABLE=True
LOGIN_RATE_LIMIT=5/5m
API_RATE_LIMIT=60/m
GENERAL_RATE_LIMIT=100/m
