{
  "name": "q360-evaluation-system",
  "version": "1.0.0",
  "description": "360 Degree Evaluation System - Modern UI with TailwindCSS",
  "main": "index.js",
  "scripts": {
    "build:css": "tailwindcss build -i ./static_src/input.css -o ./static/css/tailwind.css --minify",
    "watch:css": "tailwindcss build -i ./static_src/input.css -o ./static/css/tailwind.css --watch",
    "build": "npm run build:css",
    "dev": "npm run watch:css"
  },
  "keywords": [
    "django",
    "tailwindcss",
    "evaluation",
    "hr",
    "performance"
  ],
  "author": "Q360 Team",
  "license": "MIT",
  "devDependencies": {
    "tailwindcss": "^3.4.0"
  },
  "dependencies": {
    "caniuse-lite": "^1.0.30001751"
  }
}
